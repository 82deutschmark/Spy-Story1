<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <title>Story Adventure</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <link rel="stylesheet" href="{{ url_for('static', filename='css/custom.css') }}">
    <style>
        /* Simple loading state for choice buttons */
        .choice-button:disabled {
            opacity: 0.7;
            cursor: not-allowed;
        }
        .choice-button:disabled i {
            animation: spin 1s linear infinite;
        }
        @keyframes spin {
            0% { transform: rotate(0deg); }
            100% { transform: rotate(360deg); }
        }
    </style>
</head>
<body class="storyboard-body">
    {% if background_image %}
    <div class="story-background-container">
        <img src="{{ background_image }}" class="story-background" alt="Story Background">
    </div>
    {% endif %}

    <div class="story-main-container">
        <!-- Character Showcase -->
        <div class="character-showcase">
            {% for char in character_images[:1] %}
            <div class="character-portrait-container">
                <img src="{{ char.image_url }}" class="main-character-img" alt="{{ char.name|default('Mystery Character') }}">
            </div>
            <div class="character-info-box">
                <h3>{{ char.name|default('Mystery Character') }}</h3>
                <div class="character-traits-list">
                    {% if char.traits %}
                        {% for trait in char.traits %}
                        <span class="trait-badge">{{ trait }}</span>
                        {% endfor %}
                    {% endif %}
                </div>
            </div>
            {% endfor %}

            <!-- Character Gallery for all characters -->
            <div class="character-gallery mt-4">
                <h4 class="text-center mb-3">Characters in Story</h4>
                <div class="character-portraits-grid">
                    {% for char in character_images %}
                    <div class="character-portrait-mini" data-character-name="{{ char.name|lower|replace(' ', '-') }}">
                        <img src="{{ char.image_url }}" alt="{{ char.name }}" class="character-mini-img">
                        <div class="character-mini-name">{{ char.name }}</div>
                    </div>
                    {% endfor %}
                </div>
            </div>
        </div>

        <!-- Story Content -->
        <div class="story-content-container">
            <div class="story-title-area">
                <h1 class="story-title">{{ story.primary_conflict }}</h1>
                <p class="story-subtitle">
                    {% if story.setting %}
                        A spy thriller in {{ story.setting }}
                    {% elif story.primary_conflict %}
                        {{ story.primary_conflict }}
                    {% else %}
                        Prototype: Spy Story
                    {% endif %}
                </p>
            </div>

            <div class="story-scroll-container">
                <div class="story-content">
                    {{ node.narrative_text | safe }}
                </div>
            </div>

            <!-- Choices - Moved outside story-scroll-container -->
            <div class="choices-container mt-4">
                {% if node.branch_metadata and node.branch_metadata.choices %}
                    {% for choice in node.branch_metadata.choices %}
                    <form method="POST" action="{{ url_for('main.make_choice') }}" class="choice-form" data-form-type="choice">
                        <input type="hidden" name="previous_choice" value="{{ choice.text }}">
                        <input type="hidden" name="story_context" value="{{ node.narrative_text }}">
                        <input type="hidden" name="story_id" value="{{ story_id }}">
                        <input type="hidden" name="node_id" value="{{ node.id }}">
                        <input type="hidden" name="choice_id" value="{{ choice.id or choice.choice_id }}">
                        <!-- Character selection data - include all characters -->
                        {% for image in character_images %}
                        <input type="hidden" name="characters[]" value="{{ image.id }}">
                        {% endfor %}
                        <!-- Include conflict/setting data from the initial story -->
                        <input type="hidden" name="conflict" value="{{ story.primary_conflict|default('Unknown conflict') }}">
                        <input type="hidden" name="setting" value="{{ story.setting|default('Unknown setting') }}">
                        <input type="hidden" name="narrative_style" value="{{ story.narrative_style|default('Engaging modern style') }}">
                        <input type="hidden" name="mood" value="{{ story.mood|default('Exciting and adventurous') }}">
                        <button type="submit" class="choice-btn" 
                                {% if choice.currency_requirements %}data-currency-req='{{ choice.currency_requirements|tojson }}'{% endif %}
                                data-loading-text="<i class='fas fa-spinner fa-spin'></i> Processing...">
                            {{ choice.text }}
                        </button>
                    </form>
                    {% endfor %}
                {% else %}
                    <div class="alert alert-warning">
                        No choices available. Please refresh the page or contact support if this persists.
                    </div>
                {% endif %}
            </div>

            <!-- Add flash messages display -->
            {% with messages = get_flashed_messages(with_categories=true) %}
                {% if messages %}
                <div class="flash-messages">
                    {% for category, message in messages %}
                    <div class="alert alert-{{ category }} alert-dismissible fade show" role="alert">
                        {{ message }}
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>
                    {% endfor %}
                </div>
                {% endif %}
            {% endwith %}

            <!-- Navigation -->
            <div class="navigation-area">
                <!-- Home button removed -->
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script type="module" src="{{ url_for('static', filename='js/main.js') }}"></script>
    <script>
    document.addEventListener('DOMContentLoaded', function() {
        // Initialize ChoiceHandler
        const choiceHandler = new ChoiceHandler();
        choiceHandler.initialize();
    });
    </script>
</body>
</html>