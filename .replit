modules = ["python-3.11", "postgresql-16"]

[nix]
channel = "stable-24_05"

[deployment]
deploymentTarget = "autoscale"
run = ["sh", "-c", "gunicorn --bind 0.0.0.0:5000 'wsgi:app' --access-logfile '-' --log-level info --timeout 120"]
build = ["sh", "-c", "pip install -r requirements.txt"]

[workflows]
runButton = "Production"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
agentRequireRestartOnSave = false

[[workflows.workflow.tasks]]
task = "packager.installForAll"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python main.py"
waitForPort = 5000

[[workflows.workflow]]
name = "Start application (fixed)"
author = 38813642
mode = "sequential"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python -m main"

[[workflows.workflow]]
name = "Run"
author = 38813642
mode = "sequential"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python main.py"

[[workflows.workflow]]
name = "Run with Debug"
author = 38813642
mode = "sequential"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "FLASK_ENV=development FLASK_DEBUG=1 python main.py"

[[workflows.workflow]]
name = "Production Server"
author = 38813642
mode = "sequential"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "gunicorn --bind 0.0.0.0:80 'wsgi:app' --access-logfile '-' --log-level info"

[[workflows.workflow]]
name = "Development Server"
author = 38813642
mode = "sequential"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "FLASK_ENV=development python main.py"

[[workflows.workflow]]
name = "Production Deploy"
author = 38813642
mode = "sequential"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "FLASK_ENV=production gunicorn --bind 0.0.0.0:80 'main:create_app()' --workers=2 --timeout=120 --max-requests=1000 --max-requests-jitter=50 --log-level=info --error-logfile='-' --access-logfile='-'"

[[workflows.workflow]]
name = "Production"
author = 38813642
mode = "sequential"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "FLASK_ENV=production gunicorn --bind 0.0.0.0:5000 'wsgi:app' --access-logfile '-' --log-level info --timeout 120"

[[ports]]
localPort = 80
externalPort = 80

[[ports]]
localPort = 5000
externalPort = 5000

[[ports]]
localPort = 3000
externalPort = 3000

[[ports]]
localPort = 5000
externalPort = 5000
