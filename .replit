modules = ["python-3.11", "postgresql-16"]

[nix]
channel = "stable-24_05"

[deployment]
deploymentTarget = "autoscale"
run = ["sh", "-c", "gunicorn --bind 0.0.0.0:80 'main:create_app()' --access-logfile '-'"]
build = ["sh", "-c", "pip install -r requirements.txt"]

[workflows]
runButton = "Run with Debug"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
agentRequireRestartOnSave = false

[[workflows.workflow.tasks]]
task = "packager.installForAll"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python main.py"
waitForPort = 5000

[[workflows.workflow]]
name = "Start application (fixed)"
author = 38813642
mode = "sequential"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python -m main"

[[workflows.workflow]]
name = "Run"
author = 38813642
mode = "sequential"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python main.py"

[[workflows.workflow]]
name = "Run with Debug"
author = 38813642
mode = "sequential"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "FLASK_ENV=development FLASK_DEBUG=1 python main.py"

[[workflows.workflow]]
name = "Production Server"
author = 38813642
mode = "sequential"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "FLASK_ENV=production gunicorn --bind 0.0.0.0:3000 'main:create_app()'"

[[workflows.workflow]]
name = "Development Server"
author = 38813642
mode = "sequential"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "FLASK_ENV=development python main.py"

[[ports]]
localPort = 3000
externalPort = 3000

[[ports]]
localPort = 80
externalPort = 80
