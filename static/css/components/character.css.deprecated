/* Character Component Styles */

/* Character Card */
.character-card {
  background-color: #fff;
  border-radius: 15px;
  overflow: hidden;
  transition: transform 0.3s ease;
  box-shadow: 0 4px 8px rgba(0,0,0,0.1);
}

